{
  "name": "smart-code-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "cd .. && vite --port 5173 --strictPort",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:web": "cd .. && vite build",
    "build": "npm run build:web && electron-builder",
    "preview": "cd .. && vite preview --port 4173 --strictPort",
    "dist": "npm run build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.smartcodestudio.app",
    "productName": "Smart Code Studio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "app-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}